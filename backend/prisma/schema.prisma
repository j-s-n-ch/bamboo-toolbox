// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userUuid    String   @id @default(uuid())
  createdAt   DateTime @default(now())
  stats       PlayerStats?
  items       OwnedItem[]
}

model PlayerStats {
  userUuid            String   @id
  user                User     @relation(fields: [userUuid], references: [userUuid])
  achievementPoints   Int
  agility        Int
  carpentry      Int
  cooking        Int
  crafting       Int
  fishing        Int
  foraging       Int
  mining         Int
  smithing       Int
  trinketry      Int
  woodcutting    Int
  updatedAt           DateTime @updatedAt
}

model OwnedItem {
  userUuid  String
  itemId    String
  owned     Boolean
  quality   String?
  quality2  String?

  user      User   @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, itemId])
}
