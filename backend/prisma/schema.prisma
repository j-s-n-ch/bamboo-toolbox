// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userUuid           String              @id @default(uuid())
  createdAt          DateTime            @default(now())
  lastActiveAt       DateTime?
  stats              PlayerStat[]
  items              OwnedItem[]
  factionReputations FactionReputation[]
  gearSets           GearSet[]
  settings           UserSetting[]
}

model PlayerStat {
  userUuid String
  stat     String
  value    Int

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, stat])
}

model OwnedItem {
  userUuid         String
  itemId           String
  owned            Boolean
  hidden           Boolean @default(false)
  quantity         Int     @default(0)
  craftedTier      String?
  craftedTier2     String?
  consumableCommon Boolean @default(false)
  consumableFine   Boolean @default(false)
  petLevel         Int?
  petRarity        String?

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, itemId])
}

model FactionReputation {
  userUuid   String
  reputation String
  value      Int

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, reputation])
}

model GearSet {
  id         Int      @id @default(autoincrement())
  userUuid   String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isFavorite Boolean  @default(false)
  sortOrder  Int? // optional manual position

  user  User          @relation(fields: [userUuid], references: [userUuid])
  tags  GearSetTag[]
  items GearSetItem[]
}

enum GearSlotType {
  head
  cape
  back
  chest
  primary
  secondary
  hands
  legs
  neck
  feet
  ring
  tool
  potion
  consumable
  service
  pet
}

model GearSetItem {
  id Int @id @default(autoincrement())

  gearSet   GearSet @relation(fields: [gearSetId], references: [id])
  gearSetId Int

  slotType  GearSlotType
  slotIndex Int // e.g., 0, 1 (for ring1, ring2), or 0–5 for tools
  itemId    String
  quality   String

  @@unique([gearSetId, slotType, slotIndex])
}

model Tag {
  id       String  @id // Changed from Int @id @default(autoincrement())
  name     String  @unique
  category String? // Optional: like "skill", "mode", etc.
  icon     String?

  gearSets GearSetTag[]
}

model GearSetTag {
  gearSet   GearSet @relation(fields: [gearSetId], references: [id])
  gearSetId Int

  tag   Tag    @relation(fields: [tagId], references: [id])
  tagId String // Changed from Int

  @@id([gearSetId, tagId])
}

model UserSetting {
  userUuid String
  setting  String
  value    Boolean
  display  Int

  user User @relation(fields: [userUuid], references: [userUuid])

  @@id([userUuid, setting])
}
